# Frontend environment variables for Vite.
#
# IMPORTANT: Vite ONLY exposes variables that start with VITE_ to the browser.
# Variables without VITE_ prefix are NOT sent to the browser (they're private).
#
# WHY? Because Vite embeds these values directly into the compiled JavaScript.
# Anything you put in VITE_ will be readable by anyone who opens DevTools.
# NEVER put secrets (API keys, DB passwords) in frontend .env files.

# The backend API URL
# During development, Vite's proxy handles /api → no need to set this
# In production: https://api.roadguard.railway.app
VITE_API_URL=http://localhost:5000

# WebSocket server URL
VITE_SOCKET_URL=http://localhost:5000
